# Application
NODE_ENV=development
PORT=3000
API_VERSION=v1

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bienestar_itm

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change_this_to_a_strong_secret_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# API Keys
API_KEY_SALT_ROUNDS=10

# Rate Limiting
RATE_LIMIT_MAX_ANONYMOUS=100
RATE_LIMIT_MAX_AUTHENTICATED=500
RATE_LIMIT_WINDOW_MS=60000

# Scraping
SCRAPER_TIMEOUT_MS=30000
